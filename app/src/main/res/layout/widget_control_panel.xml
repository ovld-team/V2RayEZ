<?xml version="1.0" encoding="utf-8"?>
<!-- Classic RemoteViews-safe layout (no ConstraintLayout). Hybrid status panel. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_panel_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_panel_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_vpn_off"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_panel_toggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/widget_btn_connect"
            android:contentDescription="@string/widget_toggle_cd"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_logo_v_widget" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_panel_server"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_no_server"
        android:textColor="#A0AEC0"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_panel_metrics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="— · ↓0 · ↑0"
        android:textColor="#CBD5E1"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widget_panel_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#F87171"
        android:textSize="11sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_panel_servers"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_chip_bg"
            android:gravity="center"
            android:text="@string/widget_servers"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_panel_open"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_chip_bg"
            android:gravity="center"
            android:text="@string/widget_open"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
