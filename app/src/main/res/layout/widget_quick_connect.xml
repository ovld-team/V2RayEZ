<?xml version="1.0" encoding="utf-8"?>
<!-- Classic RemoteViews-safe layout (no ConstraintLayout). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_quick_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/widget_quick_toggle"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/widget_btn_connect"
            android:contentDescription="@string/widget_toggle_cd"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_logo_v_widget" />

        <TextView
            android:id="@+id/widget_quick_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/widget_connect"
            android:textColor="#F8FAFC"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
